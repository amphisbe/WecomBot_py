# 企业微信智能机器人回调服务 —— 环境变量配置示例
# 复制本文件为 .env 并填入真实值，.env 已被 .gitignore 排除，请勿提交到版本控制

# -------------------------------------------------------
# 企业微信配置（必填）
# -------------------------------------------------------

# 企业微信后台「智能机器人 → API模式 → 设置接收消息回调地址」中配置的 Token
WECOM_TOKEN=your_token_here

# 企业微信后台配置的 EncodingAESKey（43位字母数字）
WECOM_ENCODING_AES_KEY=your_encoding_aes_key_here

# 企业 CorpID（在「我的企业 → 企业信息」中查看，以 ww 开头）
WECOM_CORP_ID=wwxxxxxxxxxxxxxxxxxx

# -------------------------------------------------------
# 服务配置（可选，以下为默认值）
# -------------------------------------------------------

# 服务监听地址，0.0.0.0 表示监听所有网卡
APP_HOST=0.0.0.0

# 服务监听端口
APP_PORT=9002

# 日志级别：DEBUG / INFO / WARNING / ERROR / CRITICAL
# 日志文件写入项目根目录下的 logs/wecombot.log（10 MB 滚动，保留 5 个备份）
LOG_LEVEL=INFO
